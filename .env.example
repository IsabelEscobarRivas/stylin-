# ── DeployAI Auth ──────────────────────────────────────────────────────────────
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
ORG_ID=cb94c41b-0a2d-40ba-91cc-05c45f5ab4ac

# ── DeployAI Endpoints (do not change) ────────────────────────────────────────
AUTH_URL=https://api-auth.dev.deploy.ai/oauth2/token
API_URL=https://core-api.dev.deploy.ai

# ── Agent Configuration ────────────────────────────────────────────────────────
# Agent ID for GPT-4o Vision in DeployAI
VISION_AGENT_ID=GPT_4O

# ── App Configuration ──────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_IMAGE_SIZE_MB=10
# Token cache TTL in seconds (tokens expire after 3600s, refresh 5min early)
TOKEN_CACHE_TTL=3300
